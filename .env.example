# MongoDB
MONGODB_URI=your_mongodb_connection_string

# Bright Data — residential proxy (used by Amazon scraper)
BRIGHT_DATA_USERNAME=your_brightdata_username
BRIGHT_DATA_PASSWORD=your_brightdata_password
BRIGHT_DATA_PORT=22225

# Bright Data — Scraping Browser (used by Back Market, Swappa, Reebelo scrapers)
# Bright Data dashboard → Scraping Browser zone → WebSocket endpoint
BRIGHT_DATA_SCRAPING_BROWSER_WS=wss://brd-customer-<ID>-zone-scraping_browser:<PASSWORD>@brd.superproxy.io:9222

# Email (Nodemailer — Outlook/Hotmail)
EMAIL_PASSWORD=your_email_password
